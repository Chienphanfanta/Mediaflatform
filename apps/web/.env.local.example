# Copy sang .env.local và điền giá trị thật.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# NextAuth v5 — sinh secret:  openssl rand -base64 32
AUTH_SECRET=change-me-use-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Prisma (cần cho Credentials provider authorize() và Prisma adapter sau này)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/media_ops?schema=public"
