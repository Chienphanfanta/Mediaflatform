// =============================================================================
// Media Ops Platform — Prisma schema
// Postgres 15+ · ORM: Prisma 5
// Chạy: npm run db:migrate  (tạo migration)
//       npm run db:generate (sinh client)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum GroupType {
  HR
  CONTENT
  ANALYTICS
  SYSTEM
}

// Role của thành viên trong 1 group.
// SuperAdmin của hệ thống = ADMIN của group type = SYSTEM.
enum MemberRole {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  FULL
}

enum Platform {
  YOUTUBE
  FACEBOOK
  INSTAGRAM
  X
  TELEGRAM
  WHATSAPP
}

enum ChannelStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OwnershipRole {
  PRIMARY
  SECONDARY
}

// V1-REMOVED enum PostStatus {
// V1-REMOVED   DRAFT
// V1-REMOVED   REVIEWING // Staff đã submit cho Manager duyệt
// V1-REMOVED   APPROVED // Manager duyệt xong, chờ scheduledAt hoặc publish
// V1-REMOVED   SCHEDULED
// V1-REMOVED   PUBLISHED
// V1-REMOVED   PRIVATE
// V1-REMOVED   REJECTED // Bị Manager từ chối hoặc publish thất bại (xem KNOWN ISSUES về publish failure)
// V1-REMOVED }

// V1-REMOVED enum TaskStatus {
// V1-REMOVED   ASSIGNED
// V1-REMOVED   IN_PROGRESS
// V1-REMOVED   REVIEWING
// V1-REMOVED   DONE
// V1-REMOVED   CANCELLED
// V1-REMOVED   BLOCKED
// V1-REMOVED }

// V1-REMOVED enum Priority {
// V1-REMOVED   LOW
// V1-REMOVED   NORMAL
// V1-REMOVED   HIGH
// V1-REMOVED   URGENT
// V1-REMOVED }

enum AlertType {
  TOKEN_EXPIRING
  TOKEN_EXPIRED
  POLICY_VIOLATION
  COPYRIGHT_STRIKE
  VIEW_DROP
  MONETIZATION_LOST
  MONETIZATION_AT_RISK
  API_ERROR
  RATE_LIMIT
  CHANNEL_INACTIVE
  SCHEDULED_POST_FAILED
  DEADLINE_APPROACHING
  OTHER
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// V1-REMOVED enum MediaType {
// V1-REMOVED   IMAGE
// V1-REMOVED   VIDEO
// V1-REMOVED   THUMBNAIL
// V1-REMOVED }

// V1-REMOVED enum CrossPostGroupStatus {
// V1-REMOVED   DRAFT
// V1-REMOVED   SCHEDULED
// V1-REMOVED   PUBLISHING
// V1-REMOVED   PUBLISHED
// V1-REMOVED   PARTIAL // ≥1 variant fail nhưng còn lại đã đăng
// V1-REMOVED   FAILED
// V1-REMOVED }

enum JobLogStatus {
  ACTIVE
  COMPLETED
  FAILED
  STALLED
}

enum SyncPriority {
  HIGH // Channel có video published trong 24h — sync mỗi 1h
  NORMAL // Active channel — sync mỗi 6h
  LOW // Inactive (>7 ngày không đăng) — sync mỗi 24h
}

enum SyncStatus {
  SUCCESS
  FAILED
  SKIPPED // rate-limited, quota-paused, token-expired
}

enum KPIScope {
  PER_CHANNEL // KPI giao cho 1 channel (Channel.id required)
  PER_EMPLOYEE // KPI tổng giao cho nhân viên (sum tất cả channels employee phụ trách)
}

enum PeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum KPIStatus {
  NOT_STARTED // periodStart > now
  IN_PROGRESS // periodStart <= now <= periodEnd
  ACHIEVED // achievementPercent ≥ 100, period chưa end
  EXCEEDED // achievementPercent ≥ 120, period chưa end
  MISSED // periodEnd < now và achievementPercent < 100
}

// =============================================================================
// MODELS
// =============================================================================

// --- 0. Tenant -------------------------------------------------------------
// Root entity của hệ thống multi-tenant. Mọi data nghiệp vụ scope theo tenantId.
// Subdomain routing optional (Day 4+) — Day 3 chỉ resolve qua JWT.
model Tenant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique // dùng cho subdomain + routing sau này
  logoUrl          String?
  settings         Json? // timezone, currency, language, custom branding
  subscriptionTier SubscriptionTier @default(FREE)
  maxEmployees     Int              @default(10)
  maxChannels      Int              @default(20)
  status           TenantStatus     @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  users       User[]
  groups      Group[]
  channels    Channel[]
  analytics   Analytics[]
  alerts      Alert[]
  kpis        KPI[]
  departments Department[]

  @@index([slug])
  @@index([status])
}

// --- 1. User ---------------------------------------------------------------
model User {
  id            String     @id @default(cuid())
  tenantId      String
  departmentId  String?
  email         String
  password      String // bcrypt hash (xem CLAUDE.md §9 rule #1)
  name          String
  avatar        String?
  phone         String?
  position      String? // "Senior Editor", "Content Manager"
  joinDate      DateTime?
  terminateDate DateTime?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department           Department?               @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments   Department[]              @relation("DepartmentManager")
  groupMembers         GroupMember[]
  channelOwnerships    ChannelOwnership[]        @relation("ChannelOwnerships")
  devices              UserDevice[]
  notificationSettings UserNotificationSettings?
  kpis                 KPI[]                     @relation("EmployeeKPIs")
  assignedKpis         KPI[]                     @relation("KPIAssignedBy")

  // Email unique trong scope tenant (không global)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, departmentId])
}

// --- 2. Group --------------------------------------------------------------
model Group {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  type        GroupType
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members  GroupMember[]
  channels ChannelGroup[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([deletedAt])
}

// --- 3. GroupMember --------------------------------------------------------
model GroupMember {
  userId   String
  groupId  String
  role     MemberRole @default(STAFF)
  joinedAt DateTime   @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@index([role])
  @@index([groupId, role]) // "liệt kê ADMIN của 1 group"
}

// --- 4. Permission ---------------------------------------------------------
model Permission {
  id          String           @id @default(cuid())
  resource    String // 'user' | 'group' | 'channel' | 'post' | 'task' | 'analytics' | 'media' | 'setting'
  action      PermissionAction
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
}

// --- 5. RolePermission -----------------------------------------------------
// roleId lưu giá trị enum MemberRole (ADMIN/MANAGER/STAFF/VIEWER).
// Bảng seed quyền mặc định cho mỗi role — xem packages/db/prisma/seed.ts.
model RolePermission {
  roleId       MemberRole
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// --- 6. Channel ------------------------------------------------------------
model Channel {
  id             String        @id @default(cuid())
  tenantId       String
  name           String
  platform       Platform
  accountId      String // ID thật tại platform (channelId/pageId/igUserId/chatId/...)
  externalUrl    String? // Link công khai đến kênh
  description    String?
  category       String? // "Thời sự", "Giải trí", "Lifestyle"
  accessToken    String? // AES-256-GCM encrypted (TOKEN_ENCRYPTION_KEY)
  refreshToken   String? // AES-256-GCM encrypted
  tokenExpiresAt DateTime?
  status         ChannelStatus @default(ACTIVE)
  metadata       Json? // Fields riêng theo platform — xem CLAUDE.md §6
  /// Lần sync analytics gần nhất. Cron analytics scan theo `syncPriority + lastSyncedAt`
  /// để pick stale-first (xem AnalyticsCronService.smartSync).
  lastSyncedAt   DateTime?
  lastSyncError  String? // Mô tả lỗi sync gần nhất (null = OK)
  syncPriority   SyncPriority  @default(NORMAL)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  analytics  Analytics[]
  alerts     Alert[]
  groups     ChannelGroup[]
  ownerships ChannelOwnership[]
  kpis       KPI[]

  // accountId+platform unique trong scope tenant (cho phép 2 tenants connect cùng 1 kênh thật)
  @@unique([tenantId, platform, accountId])
  @@index([tenantId])
  @@index([tenantId, platform])
  @@index([tenantId, status])
  @@index([platform, status])
  @@index([tokenExpiresAt])
  @@index([syncPriority, lastSyncedAt])
  @@index([deletedAt])
}

// --- 6.1. ChannelOwnership ------------------------------------------------
// Junction Channel ↔ User: ai phụ trách kênh nào.
// PRIMARY (1 người chính/channel) | SECONDARY (nhiều người hỗ trợ).
model ChannelOwnership {
  id           String        @id @default(cuid())
  channelId    String
  employeeId   String
  role         OwnershipRole @default(SECONDARY)
  assignedAt   DateTime      @default(now())
  assignedById String? // userId của người gán (null khi seed/system)

  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  employee User    @relation("ChannelOwnerships", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([channelId, employeeId])
  @@index([channelId])
  @@index([employeeId])
  @@index([channelId, role])
}

// --- 7. ChannelGroup -------------------------------------------------------
model ChannelGroup {
  channelId String
  groupId   String
  addedAt   DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([channelId, groupId])
  @@index([channelId])
  @@index([groupId])
}

