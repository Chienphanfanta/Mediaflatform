// --- 14. JobLog ------------------------------------------------------------
// Track BullMQ job lifecycle. Mỗi processor log start/complete/fail vào đây
// để monitor + alert khi failure rate cao. KHÔNG thay BullMQ internal state —
// đây chỉ là audit trail persistent (BullMQ keys trong Redis có TTL).
model JobLog {
  id           String       @id @default(cuid())
  queueName    String // 'post-publisher' | 'analytics-sync' | 'alert-checker' | 'notification-sender'
  jobId        String // BullMQ job ID
  jobName      String? // tên process call (optional)
  status       JobLogStatus
  attemptsMade Int          @default(0)
  data         Json? // Job data payload (truncate nếu > 10KB)
  result       Json? // Result trả về khi COMPLETED
  error        String? // Stack trace truncated khi FAILED (≤ 4000 chars)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())

  @@index([queueName, status])
  @@index([queueName, createdAt])
  @@index([jobId])
  @@index([createdAt])
}

// --- 15. SyncLog ----------------------------------------------------------
// Audit trail per-channel cho analytics sync. JobLog tracking BullMQ lifecycle
// chung cho mọi queue; SyncLog domain-specific (per channel + platform + date)
// để dashboard "lịch sử sync của channel X" + alert "channel Y đã fail Z lần".
model SyncLog {
  id             String     @id @default(cuid())
  channelId      String
  platform       Platform
  date           DateTime?  @db.Date // ngày data sync (null nếu fetch hiện tại)
  status         SyncStatus
  recordsUpdated Int        @default(0)
  durationMs     Int        @default(0)
  jobId          String? // BullMQ job ID (link sang JobLog)
  errorMessage   String? // truncated 1000 chars khi FAILED/SKIPPED
  metadata       Json? // skippedReason, daysFetched, quotaUsed, ...
  createdAt      DateTime   @default(now())

  @@index([channelId, createdAt(sort: Desc)]) // "sync gần nhất của channel X"
  @@index([platform, createdAt])
  @@index([status])
  @@index([channelId, status]) // count fail của 1 channel
}

// --- 16. UserDevice ------------------------------------------------------
// Web Push subscription per device. 1 user có thể có nhiều device (laptop +
// phone + tablet). `endpoint` unique vì browser issue 1 endpoint duy nhất per
// device + service worker registration.
//
// Khi browser revoke (user uninstall PWA, clear data, hoặc subscription expire):
// web-push trả status 410 Gone → caller xoá row qua endpoint.
model UserDevice {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique // FCM/Mozilla/Apple push endpoint URL
  p256dh    String // ECDH public key (base64url)
  auth      String // Auth secret (base64url)
  userAgent String? // Phân biệt thiết bị trong UI settings
  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- 17. UserNotificationSettings ----------------------------------------
// Per-user toggle cho từng loại push. Mặc định: bật tất cả khi user lần đầu
// subscribe. User có thể tắt từng loại trong /settings/notifications.
model UserNotificationSettings {
  userId String @id

  pushEnabled       Boolean @default(true) // Master toggle (tắt = không gửi push gì)
  alertCritical     Boolean @default(true) // Severity CRITICAL/HIGH push
  alertHigh         Boolean @default(true)
  alertMedium       Boolean @default(false) // Mặc định OFF — tránh spam
  postFailed        Boolean @default(true) // SCHEDULED_POST_FAILED
  taskDeadline      Boolean @default(true) // DEADLINE_APPROACHING
  workflowApproved  Boolean @default(true) // Bài được duyệt
  workflowRejected  Boolean @default(true) // Bài bị từ chối
  workflowSubmitted Boolean @default(true) // Có bài mới chờ duyệt (Manager)
  // Multi-channel preferences (in-app, email, push)
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)

  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

