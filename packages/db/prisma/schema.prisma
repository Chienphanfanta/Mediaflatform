// --- 10. Analytics ---------------------------------------------------------
// Snapshot số liệu hàng ngày theo channel. Unique (channelId, date) để upsert idempotent.
// `tenantId` denormalize từ Channel — speed up tenant-scoped aggregate queries.
model Analytics {
  id              String   @id @default(cuid())
  tenantId        String
  channelId       String
  date            DateTime @db.Date
  platform        Platform
  views           Int      @default(0)
  watchTimeHours  Float    @default(0)
  subscribers     Int      @default(0)
  subscriberDelta Int      @default(0)
  revenue         Float    @default(0)
  engagementRate  Float    @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  raw             Json?
  fetchedAt       DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, date])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([channelId])
  @@index([date])
  @@index([platform])
  @@index([platform, date])
  @@index([channelId, date(sort: Desc)])
}

// --- 11. Alert -------------------------------------------------------------
model Alert {
  id        String        @id @default(cuid())
  tenantId  String
  channelId String
  type      AlertType
  message   String
  severity  AlertSeverity @default(MEDIUM)
  isRead    Boolean       @default(false)
  metadata  Json?
  createdAt DateTime      @default(now())
  readAt    DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isRead])
  @@index([channelId])
  @@index([isRead])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@index([channelId, isRead])
  @@index([severity, isRead])
}

// --- 11.5 KPI -------------------------------------------------------------
// Chỉ tiêu giao theo kênh hoặc theo nhân viên. achievementPercent = average
// của các target có set (followers, followersGain, views, watchTime, engagement);
// status auto theo achievementPercent + period dates.
//
// PER_CHANNEL: aggregate Analytics của 1 channel trong period.
// PER_EMPLOYEE: aggregate Analytics của tất cả channels mà employee là owner.
model KPI {
  id        String   @id @default(cuid())
  tenantId  String

  scope      KPIScope
  channelId  String? // null khi scope = PER_EMPLOYEE
  employeeId String

  periodType  PeriodType
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  // Targets — set null cho target không áp dụng
  targetFollowers     Int?
  targetFollowersGain Int? // tăng trưởng follower trong period
  targetViews         Int?
  targetWatchTime     Float?
  targetEngagement    Float?

  // Calculated automatically by KpiCronService + manual recalc
  achievementPercent Float?
  status             KPIStatus @default(NOT_STARTED)

  // Audit
  assignedById String
  assignedAt   DateTime @default(now())
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel    Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  employee   User     @relation("EmployeeKPIs", fields: [employeeId], references: [id], onDelete: Cascade)
  assignedBy User     @relation("KPIAssignedBy", fields: [assignedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId, periodStart])
  @@index([tenantId, channelId, periodStart])
  @@index([tenantId, status])
  @@index([periodEnd]) // cron tìm KPI period vừa expire
}

// --- 11.6 Department -----------------------------------------------------
// Phòng ban — V2 spec. 1 user thuộc 0-1 dept (User.departmentId), 1 dept có 0-1
// manager (Department.managerId). Cùng tenant.
model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  color       String? // hex color cho UI badge (vd "#3b82f6")
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager User?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  members User[] @relation("DepartmentMembers")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, managerId])
}

