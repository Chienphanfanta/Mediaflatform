# ============================================================================
# MEDIA OPS PLATFORM — Environment Variables
# ============================================================================
# Copy file này → `.env` (NEVER commit .env). Mọi key có dấu (★) là REQUIRED
# tối thiểu để app chạy local. Còn lại tuỳ feature/phase.
#
# Generate secrets nhanh:
#   AUTH_SECRET / JWT_SECRET / SESSION_SECRET : openssl rand -base64 32
#   ENCRYPTION_KEY                            : openssl rand -hex 32
#   VAPID keys                                : node -e "console.log(require('web-push').generateVAPIDKeys())"
# ============================================================================

# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development                    # development | production | test
APP_NAME=MediaOpsPlatform

# ─── Web (Next.js) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # ★ Public origin web app — dùng cho OAuth callbacks, email links
NEXT_PUBLIC_API_URL=http://localhost:4000   # NestJS api gateway (Phase 8 nếu cross-app HTTP)

# ─── API (NestJS) ───────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0

# ─── Database (PostgreSQL 15+) ──────────────────────────────────────────────
# ★ Required. Local dev: `docker compose up postgres` rồi dùng URL dưới.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/media_ops?schema=public

# ─── Redis 7 (Cache + BullMQ + Quota) ───────────────────────────────────────
# ★ Required. Local: `docker compose up redis`.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                              # Production managed Redis dùng password riêng

# ─── Auth / Security ────────────────────────────────────────────────────────
# ★ Tất cả secrets phải set production. Default value chỉ chạy được local.
AUTH_SECRET=change-me-use-openssl-rand-base64-32   # NextAuth JWT secret
AUTH_URL=http://localhost:3000                     # NextAuth canonical URL — match NEXT_PUBLIC_APP_URL
JWT_SECRET=change-me-in-production                 # Cross-service JWT (web → api Bearer)
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-in-production             # Cookie signing fallback

# ★ AES-256-GCM key cho mã hoá OAuth tokens trong Channel.accessToken/refreshToken.
# 32 bytes hex (= 64 chars). KHÔNG đổi sau khi có data — token cũ sẽ unreadable.
# Phase 8: cần migration script để rotate (KNOWN ISSUES #28).
ENCRYPTION_KEY=

# ─── Bull Board Dashboard (/admin/queues, apps/api) ────────────────────────
# Basic auth gate. Production thay bằng SUPERADMIN session middleware (issue #43).
BULL_BOARD_USER=admin
BULL_BOARD_PASS=change-me

# ─── Email transport (Resend HTTP API) ──────────────────────────────────────
# https://resend.com/api-keys. Nếu trống → NotificationService log warn + no-op (dev OK).
# Production: verify domain trên Resend dashboard + setup SPF/DKIM.
RESEND_API_KEY=
EMAIL_FROM="Media Ops <alerts@mediaops.app>"

# ─── Web Push (VAPID — Phase 8) ─────────────────────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY phải = VAPID_PUBLIC_KEY (client subscribe cần public).
# VAPID_SUBJECT bắt buộc bởi spec — mailto: hoặc HTTPS contact URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT="mailto:admin@mediaops.app"

# ─── Platform: YouTube (Google OAuth 2.0) ───────────────────────────────────
# https://console.cloud.google.com → New project → enable YouTube Data API v3 + Analytics API.
# OAuth consent screen → Authorized redirect URI:
#   ${AUTH_URL}/api/v1/platforms/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=

# ─── Platform: Facebook + Instagram (Meta Graph API v18+) ───────────────────
# https://developers.facebook.com/apps → Valid OAuth Redirect URIs:
#   ${AUTH_URL}/api/v1/platforms/facebook/callback
#   ${AUTH_URL}/api/v1/platforms/instagram/callback
# IG Business yêu cầu link với 1 FB Page (xem .claude/skills/platform-integrations.md).
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
FACEBOOK_REDIRECT_URI=
INSTAGRAM_REDIRECT_URI=

# ─── Platform: Telegram (Bot Token) ─────────────────────────────────────────
# Tạo bot qua @BotFather trên Telegram. Bot phải là admin của channel/group.
# KHÔNG cần OAuth — bot token = full credential per channel.
TELEGRAM_BOT_TOKEN=

# ─── Platform: X / Twitter (OAuth 2.0 + PKCE) ───────────────────────────────
# https://developer.x.com → Project → User authentication → enable OAuth 2.0.
# Callback URI: ${AUTH_URL}/api/v1/platforms/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
# Legacy v1.1 keys — chỉ cần khi media upload (issue #25).
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# ─── Platform: WhatsApp Business Cloud API ──────────────────────────────────
# Meta WhatsApp Business Platform → Phone number ID + system user access token.
# 24h window: ngoài cửa sổ chỉ gửi được template đã duyệt (issue #27).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── E2E Test (Playwright) ─────────────────────────────────────────────────
# Optional — dùng khi chạy `npx playwright test` cần override BASE_URL.
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_AUTOSTART=                       # set 1 để Playwright tự `next dev`

# ─── Observability (Phase 9) ───────────────────────────────────────────────
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
